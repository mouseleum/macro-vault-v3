# Public browser-safe value.
NEXT_PUBLIC_APP_NAME="Macro Vault v3"

# Server-only secrets. Set these in Vercel Project Settings -> Environment Variables.
VAULT_API_KEY="replace-with-a-long-random-secret"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
GEMINI_API_KEY="your-gemini-key"
# Optional. Defaults to gemini-2.5-flash-lite for lower cost and better availability.
GEMINI_MODEL="gemini-2.5-flash-lite"
# Optional. Web Intelligence can use a stronger/search-grounded model.
GEMINI_INTELLIGENCE_MODEL="gemini-2.5-flash"

# Optional provider keys. Add them only when the matching connector is enabled.
FRED_API_KEY=""
EIA_API_KEY=""
RELIEFWEB_APP_NAME=""
# Optional. Set in Vercel so the daily calendar-sync cron (vercel.json) can
# authenticate; Vercel sends it as the Authorization bearer on cron requests.
CRON_SECRET=""

# Optional: only used when the economic-calendar sync is called with provider "fmp".
# The default provider "forex_factory" is keyless. FMP calendar access needs a paid plan.
FMP_API_KEY=""
APIFY_TOKEN=""
