# Server-only secrets. Set these in Vercel Project Settings -> Environment Variables.
MARKETING_API_KEY="replace-with-a-long-random-secret"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
GEMINI_API_KEY="your-gemini-key"
# Optional. Defaults to gemini-2.5-flash-lite.
GEMINI_MODEL="gemini-2.5-flash-lite"

# Vercel injects CRON_SECRET as the bearer on cron requests once set.
CRON_SECRET=""

# Public URL of this deployment; used to build card image URLs in posts.
# Falls back to the request host when unset.
PUBLIC_BASE_URL=""

# Project feeds (see lib/registry.ts). Leave VAULT_FEED_URL unset in local dev
# to use the bundled fixture feed.
VAULT_FEED_URL="https://your-vault.vercel.app/api/marketing/highlights"
VAULT_API_KEY="the-vault's-VAULT_API_KEY"
VISUAL_ALARMIST_FEED_URL=""
VISUAL_ALARMIST_API_KEY=""

# Channels — each adapter is skipped (never fatal) until its vars are set.
ZAPIER_WEBHOOK_URL=""
LINKEDIN_ZAPIER_WEBHOOK_URL=""
BLUESKY_IDENTIFIER=""
BLUESKY_APP_PASSWORD=""
BLUESKY_SERVICE=""
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_SECRET=""

# Set to 1 to log publish payloads instead of posting.
DRY_RUN=""
